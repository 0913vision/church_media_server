# All variables are REQUIRED — the server fails fast at startup if any is
# missing or invalid (no silent defaults).
PORT=4000
# 'X32' (real mixing console) or 'MOCK' (logs only)
CONSOLE_MODE=X32
# Admin password — stored HASHED (scrypt), never plaintext.
# Generate one and paste it here:  npm run hash-password -- 'your-password'
ADMIN_PASSWORD_HASH=
# debug | info | warn | error
LOG_LEVEL=info
# X32 mixing console network location
X32_REMOTE_ADDRESS=192.168.0.3
X32_REMOTE_PORT=10023
# Path to the libmpv shared library (platform-specific).
#   macOS (Homebrew):  /opt/homebrew/lib/libmpv.dylib
#   Raspberry Pi:      /lib/arm-linux-gnueabihf/libmpv.so
MPV_LIBRARY_PATH=/opt/homebrew/lib/libmpv.dylib
# Where player preferences (volume / mute / song) are persisted across restarts
STATE_FILE_PATH=./data/state.json
